<Window x:Class="StudyPython.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StudyPython.ViewModels"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:converters="clr-namespace:StudyPython.Converters"
        Title="Python Study - 파이썬 학습 프로그램 (076923.github.io)"
        Width="1500" Height="950" MinWidth="1200" MinHeight="700"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 학생 정보 1행 -->
        <Grid Grid.Row="0" Margin="0,0,0,3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="학과" VerticalAlignment="Center" Margin="5,0" FontWeight="Bold"/>
            <TextBox Grid.Column="1" Text="{Binding Department, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>

            <TextBlock Grid.Column="3" Text="학번" VerticalAlignment="Center" Margin="5,0" FontWeight="Bold"/>
            <TextBox Grid.Column="4" Text="{Binding StudentId, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>

            <TextBlock Grid.Column="6" Text="학년" VerticalAlignment="Center" Margin="5,0" FontWeight="Bold"/>
            <TextBox Grid.Column="7" Text="{Binding Grade, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>

            <TextBlock Grid.Column="9" Text="이름" VerticalAlignment="Center" Margin="5,0" FontWeight="Bold"/>
            <TextBox Grid.Column="10" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
        </Grid>

        <!-- Row 1: 학생 정보 2행 -->
        <Grid Grid.Row="1" Margin="0,0,0,3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="소속 회사" VerticalAlignment="Center" Margin="5,0" FontWeight="Bold"/>
            <TextBox Grid.Column="1" Text="{Binding Company, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>

            <TextBlock Grid.Column="3" Text="점수" VerticalAlignment="Center" Margin="5,0" FontWeight="Bold"/>
            <TextBox Grid.Column="4" Text="{Binding Score}" VerticalAlignment="Center" IsReadOnly="True" Background="#F0F0F0"/>

            <Button Grid.Column="6" Content="작업폴더" Command="{Binding SelectWorkFolderCommand}" Padding="10,3" Margin="5,0"/>
        </Grid>

        <!-- Row 2: 메인 콘텐츠 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="2*" MinWidth="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- 왼쪽: 강좌 리스트 -->
            <GroupBox Grid.Column="0" Header="강좌 리스트" Margin="0,0,0,0">
                <ListBox x:Name="CourseListBox" ItemsSource="{Binding CourseTree}"
                         SelectionChanged="CourseListBox_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Padding="2"
                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#E0E0E0"/>

            <!-- 중앙: 본문/예제+실행결과 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 본문 내용 -->
                <GroupBox Grid.Row="0" Header="본문 내용">
                    <WebBrowser x:Name="ContentBrowser" />
                </GroupBox>

                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#E0E0E0"/>

                <!-- 예제 + 실행 결과 (좌우 배치) -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 예제 -->
                    <GroupBox Grid.Column="0" Header="예제">
                        <DockPanel>
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,3">
                                <Button DockPanel.Dock="Right" Content="실행" Command="{Binding RunExampleCommand}"
                                        Padding="15,3" Margin="5,0,0,0" Background="#4A90D9" Foreground="White"/>
                                <ComboBox ItemsSource="{Binding CodeExamples}" SelectedItem="{Binding SelectedExample, Mode=TwoWay}"
                                          DisplayMemberPath="Title"/>
                            </DockPanel>
                            <TextBox Text="{Binding SelectedExampleCode, Mode=OneWay}" IsReadOnly="True"
                                     FontFamily="Consolas" FontSize="12" Background="#F8F8F8"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap" AcceptsReturn="True"/>
                        </DockPanel>
                    </GroupBox>

                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#E0E0E0"/>

                    <!-- 실행 결과 (예제) -->
                    <GroupBox Grid.Column="2" Header="실행 결과">
                        <TextBox Text="{Binding ExampleResult, Mode=OneWay}" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="12" Background="#F0F8FF"
                                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                    </GroupBox>
                </Grid>
            </Grid>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="#E0E0E0"/>

            <!-- 오른쪽: 에디터/실행결과/REPL -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="4*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 파이썬 에디터 -->
                <GroupBox Grid.Row="0" Header="파이썬 에디터">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,3">
                            <Button Content="NEW" Command="{Binding NewFileCommand}" Padding="8,3" Margin="0,0,3,0"/>
                            <Button Content="OPEN" Command="{Binding OpenFileCommand}" Padding="8,3" Margin="0,0,3,0"/>
                            <Button Content="SAVE" Command="{Binding SaveFileCommand}" Padding="8,3" Margin="0,0,15,0"/>
                            <Button Content="시작" Command="{Binding RunCodeCommand}" Padding="8,3" Margin="0,0,3,0"
                                    Background="#27AE60" Foreground="White"/>
                            <Button Content="정지" Command="{Binding StopCodeCommand}" Padding="8,3"
                                    Background="#E74C3C" Foreground="White"/>
                        </StackPanel>
                        <!-- 탭 헤더만 표시 -->
                        <TabControl x:Name="EditorTabControl" DockPanel.Dock="Top"
                                    ItemsSource="{Binding EditorTabs}" SelectedItem="{Binding SelectedTab}"
                                    SelectionChanged="EditorTabControl_SelectionChanged"
                                    Padding="0" Margin="0,0,0,0">
                            <TabControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Title}" Margin="0,0,5,0"/>
                                        <Button Content="×" FontSize="10" Padding="2,0"
                                                Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </TabControl.ItemTemplate>
                            <TabControl.ContentTemplate>
                                <DataTemplate>
                                    <!-- 빈 콘텐츠 - 에디터는 TabControl 밖에 배치 -->
                                    <Border Height="0"/>
                                </DataTemplate>
                            </TabControl.ContentTemplate>
                        </TabControl>
                        <!-- 단일 AvalonEdit 인스턴스 -->
                        <avalon:TextEditor x:Name="PythonEditor"
                                           FontFamily="Consolas" FontSize="13"
                                           ShowLineNumbers="True"
                                           Background="White"/>
                    </DockPanel>
                </GroupBox>

                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#E0E0E0"/>

                <!-- 실행 결과 (에디터) -->
                <GroupBox Grid.Row="2" Header="실행 결과">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,3,0,0">
                            <Button Content="지우기" Command="{Binding ClearResultCommand}" Padding="10,3" Margin="0,0,5,0"/>
                            <Button Content="출력" Command="{Binding ExportPdfCommand}" Padding="10,3" Margin="0,0,5,0"
                                    Background="#2980B9" Foreground="White"/>
                            <Button Content="제출" Command="{Binding SubmitCommand}" Padding="10,3"
                                    Background="#8E44AD" Foreground="White"/>
                        </StackPanel>
                        <TextBox x:Name="EditorResultBox" Text="{Binding EditorResult, Mode=OneWay}" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="12" Background="#F0F8FF"
                                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                    </DockPanel>
                </GroupBox>

                <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" Background="#E0E0E0"/>

                <!-- REPL -->
                <GroupBox Grid.Row="4" Header="REPL">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Bottom" Margin="0,3,0,0">
                            <TextBlock Text="&gt;&gt;&gt; " VerticalAlignment="Center" FontFamily="Consolas" FontSize="12"/>
                            <TextBox x:Name="ReplInput" Text="{Binding ReplInput, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas" FontSize="12"
                                     KeyDown="ReplInput_KeyDown"/>
                        </DockPanel>
                        <TextBox Text="{Binding ReplOutput, Mode=OneWay}" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="12" Background="#1E1E1E" Foreground="#D4D4D4"
                                 VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                                 x:Name="ReplOutputBox"/>
                    </DockPanel>
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
</Window>
